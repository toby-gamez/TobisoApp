<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Pro development - povolí unsafe connections k tobiso.com -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">tobiso.com</domain>
        <domain includeSubdomains="true">www.tobiso.com</domain>
        <domain includeSubdomains="true">formspree.io</domain>
        <!-- Důvěřuj všem certifikátům pro tobiso.com -->
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>
    
    <!-- Debug override pro development build -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>

