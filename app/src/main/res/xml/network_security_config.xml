<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Konfigurace pro tobiso.com -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">tobiso.com</domain>
        <domain includeSubdomains="true">www.tobiso.com</domain>
        <!-- Certificate pinning – hashi vygenerovány 2026-03-19 pomocí get_ssl_hash.sh -->
        <pin-set expiration="2027-03-19">
            <pin digest="SHA-256">i0rpPYzV8YE/KbZ7yWnCBqTdW5LcUhWRXomSrxWFkEU=</pin>
            <pin digest="SHA-256">r/tLBf9qkHs3KP7qtA2tjoDCw4GSKnyoxjEycJRblyg=</pin>
        </pin-set>
    </domain-config>
    
    <!-- Konfigurace pro ostatní služby -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">formspree.io</domain>
        <trust-anchors>
            <!-- Používej pouze systémové CA v produkci -->
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
    
    <!-- Globální nastavení pro ostatní domény -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    
    <!-- Debug override - POUZE pro development buildy -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <!-- Povolit user certifikáty pouze pro debug -->
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>

