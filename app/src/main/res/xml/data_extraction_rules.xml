<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Uživatelský pokrok – zahrnout do zálohy -->
        <include domain="sharedpref" path="ProfilePrefs.xml"/>
        <include domain="sharedpref" path="StreakData.xml"/>
        <include domain="sharedpref" path="streak_milestones.xml"/>
        <include domain="sharedpref" path="streak_prefs.xml"/>
        <include domain="sharedpref" path="streak_freeze_prefs.xml"/>
        <include domain="sharedpref" path="points_prefs.xml"/>
        <include domain="sharedpref" path="points_achievements.xml"/>
        <include domain="sharedpref" path="shop_prefs.xml"/>
        <include domain="sharedpref" path="backpack_prefs.xml"/>
        <include domain="sharedpref" path="PetBubblePrefs.xml"/>

        <!-- Citlivá a zařízení-specifická data – vyloučit ze zálohy -->
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="sharedpref" path="app_usage_prefs.xml"/>

        <!-- Room databáze (offline cache) – není třeba zálohovat, data se stáhnou ze serveru -->
        <exclude domain="database" path="tobiso_offline.db"/>
        <exclude domain="database" path="tobiso_offline.db-shm"/>
        <exclude domain="database" path="tobiso_offline.db-wal"/>
    </cloud-backup>

    <device-transfer>
        <!-- Při přenosu zařízení přenést veškerý uživatelský pokrok -->
        <include domain="sharedpref" path="ProfilePrefs.xml"/>
        <include domain="sharedpref" path="StreakData.xml"/>
        <include domain="sharedpref" path="streak_milestones.xml"/>
        <include domain="sharedpref" path="streak_prefs.xml"/>
        <include domain="sharedpref" path="streak_freeze_prefs.xml"/>
        <include domain="sharedpref" path="points_prefs.xml"/>
        <include domain="sharedpref" path="points_achievements.xml"/>
        <include domain="sharedpref" path="shop_prefs.xml"/>
        <include domain="sharedpref" path="backpack_prefs.xml"/>
        <include domain="sharedpref" path="PetBubblePrefs.xml"/>

        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="sharedpref" path="app_usage_prefs.xml"/>
        <exclude domain="database" path="tobiso_offline.db"/>
        <exclude domain="database" path="tobiso_offline.db-shm"/>
        <exclude domain="database" path="tobiso_offline.db-wal"/>
    </device-transfer>
</data-extraction-rules>