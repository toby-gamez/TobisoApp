<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="ProfilePrefs.xml"/>

        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="sharedpref" path="app_usage_prefs.xml"/>
        <exclude domain="sharedpref" path="StreakData.xml"/>
        <exclude domain="sharedpref" path="streak_milestones.xml"/>
        <exclude domain="sharedpref" path="streak_prefs.xml"/>
        <exclude domain="sharedpref" path="streak_freeze_prefs.xml"/>
        <exclude domain="sharedpref" path="points_prefs.xml"/>
        <exclude domain="sharedpref" path="points_achievements.xml"/>
        <exclude domain="sharedpref" path="shop_prefs.xml"/>
        <exclude domain="sharedpref" path="backpack_prefs.xml"/>
        <exclude domain="sharedpref" path="PetBubblePrefs.xml"/>

        <exclude domain="database" path="tobiso_offline.db"/>
        <exclude domain="database" path="tobiso_offline.db-shm"/>
        <exclude domain="database" path="tobiso_offline.db-wal"/>
    </cloud-backup>

    <device-transfer>
        <include domain="sharedpref" path="ProfilePrefs.xml"/>

        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="sharedpref" path="app_usage_prefs.xml"/>
        <exclude domain="sharedpref" path="StreakData.xml"/>
        <exclude domain="sharedpref" path="streak_milestones.xml"/>
        <exclude domain="sharedpref" path="streak_prefs.xml"/>
        <exclude domain="sharedpref" path="streak_freeze_prefs.xml"/>
        <exclude domain="sharedpref" path="points_prefs.xml"/>
        <exclude domain="sharedpref" path="points_achievements.xml"/>
        <exclude domain="sharedpref" path="shop_prefs.xml"/>
        <exclude domain="sharedpref" path="backpack_prefs.xml"/>
        <exclude domain="sharedpref" path="PetBubblePrefs.xml"/>
        <exclude domain="database" path="tobiso_offline.db"/>
        <exclude domain="database" path="tobiso_offline.db-shm"/>
        <exclude domain="database" path="tobiso_offline.db-wal"/>
    </device-transfer>
</data-extraction-rules>